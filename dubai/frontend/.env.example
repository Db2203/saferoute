# Vector basemap key (optional). Without it, the app falls back to the
# offline self-hosted PMTiles basemap. Get a free key at maptiler.com.
NEXT_PUBLIC_MAPTILER_KEY=your-maptiler-key

# Backend API base URL. Dubai runs on port 8001 (frontend on 3001) so it can
# run side-by-side with the London SafeRoute app, which uses 8000/3000.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8001
